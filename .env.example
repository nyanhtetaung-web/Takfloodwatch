# Turso Cloud credentials. Keep the auth token secret.
TURSO_DATABASE_URL=libsql://your-database-your-organization.turso.io
TURSO_AUTH_TOKEN=your-database-token
VAPID_PUBLIC_KEY=generate-with-web-push
VAPID_PRIVATE_KEY=keep-secret
VAPID_SUBJECT=https://your-dashboard.vercel.app
ALERT_ADMIN_TOKEN=generate-a-long-random-secret
CRON_SECRET=generate-a-different-long-random-secret
# LINE Messaging API. Store the secret and access token only in server-side
# environment variables. The add-friend URL is the public LINE Official Account link.
LINE_CHANNEL_SECRET=copy-from-line-developers-console
LINE_CHANNEL_ACCESS_TOKEN=issue-in-line-developers-console
LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-official-account
NEXT_PUBLIC_SITE_URL=https://your-dashboard.vercel.app
# Optional: enables official TMD NWP point forecasts for all five districts.
# Without it, the dashboard uses a clearly labelled multi-model point forecast
# while retaining the official TMD Tak forecast as the province reference.
TMD_NWP_API_TOKEN=your-tmd-nwp-oauth-token
