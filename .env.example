# Turso Cloud credentials. Keep the auth token secret.
TURSO_DATABASE_URL=libsql://your-database-your-organization.turso.io
TURSO_AUTH_TOKEN=your-database-token
VAPID_PUBLIC_KEY=generate-with-web-push
VAPID_PRIVATE_KEY=keep-secret
VAPID_SUBJECT=https://your-dashboard.vercel.app
ALERT_ADMIN_TOKEN=generate-a-long-random-secret
CRON_SECRET=generate-a-different-long-random-secret
